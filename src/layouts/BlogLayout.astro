---
import BaseLayout from './BaseLayout.astro';
import TOC from '../components/TOC.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  date?: string;
  tags?: string[];
  headings?: Heading[];
}

const { title, description, date, tags = [], headings = [] } = Astro.props;

const formatted = date
  ? new Date(date).toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })
  : undefined;

const hasTOC = headings.filter(h => h.depth === 2 || h.depth === 3).length > 0;
---

<BaseLayout title={title} description={description}>
  <div class={`article-outer ${hasTOC ? 'has-toc' : ''}`}>

    <article class="article">
      <div class="article-header">
        <div class="article-meta">
          {formatted && <time class="article-date">{formatted}</time>}
          {tags.length > 0 && (
            <div class="article-tags">
              {tags.map(tag => <span class="article-tag">{tag}</span>)}
            </div>
          )}
        </div>
        <h1 class="article-title">{title}</h1>
        {description && <p class="article-desc">{description}</p>}
      </div>

      <div class="article-body">
        <slot />
      </div>

      <div class="article-footer">
        <a href="/blog" class="back-link">← 返回文章列表</a>
      </div>
    </article>

    {hasTOC && (
      <div class="toc-col">
        <TOC headings={headings} />
      </div>
    )}

  </div>
</BaseLayout>

<style>
.article-outer {
  max-width: 760px;
  margin: 0 auto;
  padding: 60px 24px 100px;
}

.article-outer.has-toc {
  max-width: 1020px;
  display: grid;
  grid-template-columns: 1fr 200px;
  gap: 56px;
  align-items: start;
}

.article-header {
  margin-bottom: 48px;
  padding-bottom: 32px;
  border-bottom: 1px solid var(--border);
  animation: fade-in-up 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
}

.article-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 20px;
}

.article-date {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--muted);
}

.article-tags {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.article-tag {
  font-family: var(--font-mono);
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 4px;
  background: var(--accent-bg);
  color: var(--accent);
  border: 1px solid var(--border-accent);
}

.article-title {
  font-size: clamp(26px, 5vw, 38px);
  margin-bottom: 12px;
  letter-spacing: -0.03em;
}

.article-desc {
  color: var(--text-secondary);
  font-size: 15px;
  line-height: 1.75;
}

/* Prose */
.article-body :global(h2) {
  font-size: 20px;
  margin: 48px 0 16px;
  padding-left: 14px;
  border-left: 3px solid var(--accent);
  color: var(--text);
  scroll-margin-top: 80px;
}

.article-body :global(h3) {
  font-size: 16px;
  margin: 32px 0 10px;
  color: var(--text);
  scroll-margin-top: 80px;
}

.article-body :global(p) {
  color: var(--text-secondary);
  margin-bottom: 18px;
  line-height: 1.88;
  font-size: 15px;
}

.article-body :global(ul),
.article-body :global(ol) {
  color: var(--text-secondary);
  padding-left: 24px;
  margin-bottom: 18px;
}

.article-body :global(li) {
  margin-bottom: 6px;
  font-size: 15px;
  line-height: 1.75;
}

.article-body :global(table) {
  width: 100%;
  border-collapse: collapse;
  margin-bottom: 24px;
  font-size: 13px;
}

.article-body :global(th),
.article-body :global(td) {
  padding: 8px 14px;
  border: 1px solid var(--border);
  text-align: left;
}

.article-body :global(th) {
  background: var(--bg-card);
  color: var(--text);
  font-family: var(--font-mono);
  font-size: 12px;
}

.article-body :global(td) {
  color: var(--text-secondary);
}

.article-body :global(code) {
  font-family: var(--font-mono);
  font-size: 13px;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid var(--border);
  padding: 1px 6px;
  border-radius: 4px;
  color: var(--accent);
}

.article-body :global(pre) {
  background: oklch(0.12 0.012 24);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px;
  overflow-x: auto;
  margin-bottom: 24px;
}

.article-body :global(pre code) {
  background: none;
  border: none;
  padding: 0;
  color: oklch(0.80 0.08 24);
  font-size: 13px;
}

.article-body :global(blockquote) {
  border-left: 3px solid var(--accent);
  padding-left: 20px;
  margin: 24px 0;
  color: var(--muted);
  font-style: italic;
}

.article-body :global(a) {
  color: var(--accent);
  text-decoration: underline;
  text-decoration-color: var(--accent-glow);
  text-underline-offset: 3px;
  transition: text-decoration-color 0.15s;
}

.article-body :global(a:hover) {
  text-decoration-color: var(--accent);
}

.article-body :global(img) {
  border-radius: var(--radius);
  border: 1px solid var(--border);
  margin: 24px 0;
}

.article-body :global(hr) {
  border: none;
  border-top: 1px solid var(--border);
  margin: 40px 0;
}

.article-footer {
  margin-top: 60px;
  padding-top: 24px;
  border-top: 1px solid var(--border);
}

.back-link {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--muted);
  transition: color 0.15s;
}
.back-link:hover { color: var(--accent); }

.toc-col {
  padding-top: 8px;
}

@media (max-width: 800px) {
  .article-outer.has-toc {
    grid-template-columns: 1fr;
  }
  .toc-col { display: none; }
}
</style>
