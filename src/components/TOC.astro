---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filtered = headings.filter(h => h.depth === 2 || h.depth === 3);
---

{filtered.length > 0 && (
  <aside class="toc">
    <div class="toc-header">
      <span class="toc-title">目錄</span>
      <div class="toc-progress-wrap">
        <div class="toc-progress-bar" id="toc-progress"></div>
      </div>
    </div>
    <nav>
      <ul class="toc-list">
        {filtered.map(h => (
          <li class={`toc-item ${h.depth === 3 ? 'toc-sub' : ''}`} data-slug={h.slug}>
            <a href={`#${h.slug}`} class="toc-link">{h.text}</a>
          </li>
        ))}
      </ul>
    </nav>
  </aside>
)}

<script>
  const items = document.querySelectorAll<HTMLElement>('.toc-item');
  const progressBar = document.getElementById('toc-progress');

  // Scroll progress
  function updateProgress() {
    const el = document.documentElement;
    const scrolled = el.scrollTop / (el.scrollHeight - el.clientHeight);
    if (progressBar) progressBar.style.width = `${Math.round(scrolled * 100)}%`;
  }

  // Active heading via IntersectionObserver
  const headingEls = document.querySelectorAll<HTMLElement>('article h2, article h3');
  let activeSlug = '';

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          activeSlug = entry.target.id;
          items.forEach(item => {
            item.classList.toggle('active', item.dataset.slug === activeSlug);
          });
        }
      });
    },
    { rootMargin: '-20% 0px -70% 0px', threshold: 0 }
  );

  headingEls.forEach(el => observer.observe(el));

  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();
</script>

<style>
.toc {
  position: sticky;
  top: 80px;
  max-height: calc(100vh - 120px);
  overflow-y: auto;
  scrollbar-width: none;
}
.toc::-webkit-scrollbar { display: none; }

.toc-header {
  margin-bottom: 14px;
}

.toc-title {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 2px;
  color: var(--accent);
  text-transform: uppercase;
  display: block;
  margin-bottom: 8px;
}

.toc-progress-wrap {
  height: 2px;
  background: var(--border);
  border-radius: 1px;
  overflow: hidden;
}

.toc-progress-bar {
  height: 100%;
  width: 0%;
  background: var(--accent);
  border-radius: 1px;
  transition: width 0.2s;
}

.toc-list {
  list-style: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.toc-item {
  border-left: 2px solid var(--border);
  transition: border-color 0.2s;
}

.toc-item.active {
  border-left-color: var(--accent);
  animation: tocPulse 2s ease-in-out infinite;
}

@keyframes tocPulse {
  0%, 100% { border-left-color: var(--accent); }
  50% { border-left-color: oklch(0.70 0.18 24 / 0.4); }
}

.toc-sub {
  padding-left: 8px;
}

.toc-link {
  display: block;
  font-size: 12px;
  color: var(--muted);
  padding: 4px 10px;
  line-height: 1.4;
  transition: color 0.15s, background 0.15s;
  border-radius: 0 4px 4px 0;
}

.toc-link:hover {
  color: var(--text);
  background: rgba(255, 255, 255, 0.04);
}

.toc-item.active .toc-link {
  color: var(--accent);
  background: oklch(0.16 0.02 24);
}

.toc-sub .toc-link {
  font-size: 11px;
}
</style>
