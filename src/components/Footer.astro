---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <span class="footer-copy">© {year} BoYuan Lin</span>
    <span class="footer-sep">·</span>
    <span class="footer-built">Built with Astro</span>
  </div>
</footer>

<style>
.footer {
  position: relative;
  z-index: 10;
  border-top: 1px solid var(--border);
  padding: 24px;
  margin-top: 80px;
}

.footer-inner {
  max-width: 860px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--muted);
}

.footer-sep { opacity: 0.4; }
</style>
