---
import { getLangFromUrl, getAlternatePath } from '../i18n/utils';
import { t } from '../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const tr = t(lang);
const currentPath = Astro.url.pathname;
const alternatePath = getAlternatePath(Astro.url);

const prefix = lang === 'en' ? '/en' : '';

const links = [
  { href: `${prefix}/`, label: tr.nav.home },
  { href: `${prefix}/blog`, label: tr.nav.blog },
  { href: `${prefix}/projects`, label: tr.nav.projects },
  { href: `${prefix}/about`, label: tr.nav.about },
];

function isActive(href: string) {
  if (href === `${prefix}/` || href === '/en') return currentPath === href || currentPath === '/en/';
  return currentPath.startsWith(href);
}
---

<nav class="nav">
  <div class="nav-inner">
    <a href={`${prefix}/`} class="nav-logo">
      <span class="nav-logo-dot"></span>
      <span class="nav-logo-name glow">IapetusYuan</span>
    </a>

    <div class="nav-links">
      {links.map(link => (
        <a
          href={link.href}
          class={`nav-link ${isActive(link.href) ? 'active' : ''}`}
        >
          {link.label}
        </a>
      ))}
      <a href={alternatePath} class="lang-toggle" title="Switch language">
        {tr.nav.langToggle}
      </a>
    </div>
  </div>
</nav>

<style>
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  border-bottom: 1px solid var(--border);
  background: rgba(7, 7, 7, 0.75);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.nav-inner {
  max-width: 860px;
  margin: 0 auto;
  padding: 0 24px;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 8px;
  font-weight: 600;
  font-size: 14px;
  letter-spacing: -0.01em;
  transition: opacity 0.15s;
}
.nav-logo:hover { opacity: 0.8; }

.nav-logo-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--accent);
  animation: aiTwinkle 2.4s ease-in-out infinite;
}

.nav-logo-name { color: var(--text); }
.nav-logo-name.glow { animation: aiSoftGlow 4.8s ease-in-out infinite; }

.nav-links {
  display: flex;
  align-items: center;
  gap: 2px;
}

.nav-link {
  font-family: var(--font-mono);
  font-size: 12px;
  padding: 6px 12px;
  border-radius: 8px;
  color: var(--muted);
  transition: color 0.15s, background 0.15s;
}

.nav-link:hover {
  color: var(--text);
  background: rgba(255, 255, 255, 0.05);
}

.nav-link.active {
  color: var(--accent);
  background: var(--accent-bg);
}

.lang-toggle {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 1px;
  color: var(--muted);
  padding: 4px 10px;
  border: 1px solid var(--border);
  border-radius: 20px;
  margin-left: 6px;
  transition: all 0.15s;
}
.lang-toggle:hover {
  border-color: var(--accent);
  color: var(--accent);
}

@media (max-width: 480px) {
  .nav-logo-name { display: none; }
  .nav-link { padding: 6px 8px; font-size: 11px; }
  .lang-toggle { margin-left: 2px; padding: 4px 8px; }
}
</style>
