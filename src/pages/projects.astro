---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    name: 'Ericsson EIAP O-RAN rApp',
    desc: 'CSAR 打包 + 無 sudo 離線部署，BDR 認證鏈 (OAuth2 → STS WebIdentity → AWS SigV4) 用於 CM/PM 資料存取。',
    tags: ['Python', 'O-RAN', 'K8s', 'OAuth2'],
    mediaType: 'IMG',
    status: '內部部署',
    company: 'Groundhog Technologies',
  },
  {
    name: 'AI KPI 異常偵測 Agent',
    desc: 'FastAPI + 本地 LLM (Gemma) + ClickHouse 架構，用於網路優化團隊的 KPI 異常根因分析。',
    tags: ['FastAPI', 'LLM', 'ClickHouse', 'Python'],
    mediaType: 'GIF',
    status: '生產環境',
    company: 'Groundhog Technologies',
  },
  {
    name: 'ClickHouse 分散式查詢修復',
    desc: '追蹤 ClickHouse 637 GB RSS 記憶體暴漲根因，修復 IN → GLOBAL IN，恢復 20,238 列資料攝取管線。',
    tags: ['ClickHouse', 'SQL', 'Python', 'Debug'],
    mediaType: 'IMG',
    status: '內部工具',
    company: 'Groundhog Technologies',
  },
  {
    name: '弱監督學習婦科癌症 WSI 分析',
    desc: '碩士論文：以改良版 CLAM 模型預測子宮內膜癌 MSI 狀態，整合 Shuffle Attention, Modified-FCN, VarMIL。',
    tags: ['PyTorch', 'TensorFlow', 'Deep Learning', 'ResNet'],
    mediaType: 'IMG',
    status: '研究',
    company: 'NTUST',
  },
  {
    name: '深度學習人臉辨識點名系統',
    desc: '大學畢業專題：Google Colab 訓練，Raspberry Pi 部署，自建 Web App 整合。',
    tags: ['Deep Learning', 'Raspberry Pi', 'Python', 'Web'],
    mediaType: 'IMG',
    status: '畢業專題',
    company: 'MCUT',
  },
  {
    name: 'Voronoi/Delaunay 演算法 Java→Python 遷移',
    desc: '將 JVM 服務中的 Voronoi/Delaunay 鄰居演算法從 Java 遷移至 Python，並驗證輸出一致性。',
    tags: ['Python', 'Java', 'Kubernetes', 'Docker'],
    mediaType: 'IMG',
    status: '內部工具',
    company: 'Groundhog Technologies',
  },
];
---

<BaseLayout title="作品集" description="工程實踐、AI 研究與系統建設的作品展示">
  <div class="container">

    <header class="page-header fade-in-up">
      <h1 class="page-title">作品集</h1>
      <p class="page-sub">工程實踐 · AI 研究 · 系統建設</p>
      <p class="page-note">
        多數作品為內部系統，以截圖或 GIF 呈現。
        <span class="mono muted">// 圖片陸續更新中</span>
      </p>
    </header>

    <div class="projects-grid">
      {projects.map((p, i) => (
        <div class={`project-card fade-in-up fade-in-up-${Math.min(i + 1, 4)}`}>
          <div class="project-media">
            <span class="media-placeholder">{p.name}</span>
            <span class="media-badge">{p.mediaType}</span>
          </div>
          <div class="project-body">
            <div class="project-meta">
              <span class="project-company">{p.company}</span>
              <span class="project-status">{p.status}</span>
            </div>
            <h2 class="project-name">{p.name}</h2>
            <p class="project-desc">{p.desc}</p>
            <div class="project-tags">
              {p.tags.map(tag => <span class="ptag">{tag}</span>)}
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
.container {
  max-width: 940px;
  margin: 0 auto;
  padding: 60px 24px 100px;
}

.page-header { margin-bottom: 40px; }

.page-title {
  font-size: clamp(26px, 5vw, 34px);
  font-weight: 700;
  letter-spacing: -0.03em;
  margin-bottom: 6px;
}

.page-sub {
  color: var(--muted);
  font-size: 13px;
  margin-bottom: 6px;
}

.page-note {
  font-size: 12px;
  color: var(--muted);
}

.projects-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
}

.project-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  transition: all 0.3s;
}

.project-card:hover {
  border-color: oklch(0.38 0.09 var(--hue));
  transform: translateY(-4px);
  box-shadow: 0 16px 40px oklch(0.70 0.18 var(--hue) / 0.10);
}

.project-media {
  height: 160px;
  background: oklch(0.11 0.012 var(--hue));
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.project-media img, .project-media video {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.media-placeholder {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--muted);
  letter-spacing: 0.5px;
  text-align: center;
  padding: 0 16px;
  opacity: 0.5;
}

.media-badge {
  position: absolute;
  top: 10px;
  right: 10px;
  background: var(--accent);
  color: #000;
  font-size: 9px;
  font-weight: 700;
  padding: 2px 7px;
  border-radius: 4px;
  font-family: var(--font-mono);
}

.project-body { padding: 16px 18px; }

.project-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.project-company {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--accent);
  letter-spacing: 1px;
}

.project-status {
  font-size: 10px;
  color: var(--muted);
  border: 1px solid var(--border);
  padding: 2px 8px;
  border-radius: 10px;
  font-family: var(--font-mono);
}

.project-name {
  font-size: 15px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 6px;
  letter-spacing: -0.01em;
}

.project-desc {
  font-size: 12px;
  color: var(--muted);
  line-height: 1.65;
  margin-bottom: 12px;
}

.project-tags {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.ptag {
  font-size: 10px;
  color: var(--muted);
  background: oklch(0.19 0.015 var(--hue));
  padding: 2px 8px;
  border-radius: 10px;
  font-family: var(--font-mono);
}

@media (max-width: 640px) {
  .projects-grid { grid-template-columns: 1fr; }
}
</style>
