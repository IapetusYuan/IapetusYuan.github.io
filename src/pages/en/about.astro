---
import BaseLayout from '../../layouts/BaseLayout.astro';

const experience = [
  {
    period: 'Aug 2024 – Present',
    title: 'Software Engineer',
    org: 'Groundhog Technologies · Taipei, Taiwan',
    bullets: [
      'Built AI KPI-anomaly-detection agents (FastAPI + Gemma + ClickHouse); root-caused routing instability to token skew',
      'Delivered Ericsson EIAP O-RAN rApp end-to-end — CSAR packaging + offline deployment, BDR OAuth2/STS/SigV4 auth chain',
      'Owned live production root-cause analysis for tier-1 telecom carriers (traced ClickHouse 637 GB RSS blow-up)',
      'Fixed deep ClickHouse/MySQL defects: rewrote distributed subqueries (IN → GLOBAL IN), repaired IPv6 JDBC parsing',
      'Designed structured error-code taxonomy (E01–E13/W01–W04) across multi-RAT modules, shipped via Jenkins CI/CD',
      'Containerized JVM services on Kubernetes; migrated Voronoi/Delaunay from Java to Python with validated parity',
    ],
  },
  {
    period: 'Sep 2019 – Oct 2020',
    title: 'IT Intern',
    org: 'Inteplast Group Corporation · Texas, USA',
    bullets: [
      'Modernized factory data flow (MySQL → AS400), built remote-ops batch tooling, maintained Windows servers',
    ],
  },
];

const education = [
  {
    period: '2021 – 2023',
    title: 'M.S., Institute of Biomedical Engineering',
    org: 'National Taiwan University of Science and Technology (NTUST) · GPA 3.93',
    note: 'Thesis: Weakly Supervised Learning for Gynecological Cancer — integrated Shuffle Attention, Modified-FCN, and VarMIL approaches for MSI-status prediction from H&E whole-slide images (TCGA + Tri-Service General Hospital), PyTorch/TensorFlow.',
  },
  {
    period: '2017 – 2021',
    title: 'B.S., Department of Electronic Engineering',
    org: 'Ming Chi University of Science and Technology (MCUT) · GPA 3.43',
    note: 'Capstone: Deep-learning face-recognition roll-call system trained on Google Colab, deployed on Raspberry Pi, integrated into a self-built web app.',
  },
];

const skillCategories = {
  'Languages': ['Python', 'Java', 'C++', 'SQL', 'Shell'],
  'Data & Infrastructure': ['ClickHouse', 'MySQL', 'Kubernetes', 'Docker', 'Jenkins CI/CD', 'Apache Airflow', 'FastAPI'],
  'AI / ML': ['LLM Agents', 'PyTorch', 'TensorFlow', 'Deep Learning', 'Computer Vision', 'Weakly Supervised Learning'],
  'Domain': ['O-RAN / EIAP rApp', 'Telecom network optimization (LTE/NSA/SA/NR)', 'Production debugging at carrier scale', 'Telecom data analysis'],
};
---

<BaseLayout title="About" description="BoYuan Lin — background, experience, and tech stack.">
  <div class="container">

    <section class="about-hero fade-in-up">
      <div class="avatar-wrap">
        <img src="/avatar.jpg" alt="BoYuan Lin" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
        <div class="avatar-fallback">BY</div>
      </div>
      <div class="about-intro">
        <h1 class="intro-name">BoYuan Lin</h1>
        <div class="intro-role">Software Engineer · ML Researcher</div>
        <p class="intro-bio">
          Software engineer with an M.S. in deep learning for medical image analysis.
          Currently at Groundhog Technologies working on tier-1 telecom production debugging,
          O-RAN system integration, and AI agent development.
          This is where I keep technical notes, paper summaries, and engineering practice.
        </p>
        <div class="intro-socials">
          <a href="https://github.com/IapetusYuan" class="social-link" target="_blank" rel="noopener">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
            GitHub
          </a>
          <a href="mailto:linsc1012@gmail.com" class="social-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            linsc1012@gmail.com
          </a>
        </div>
      </div>
    </section>

    <section class="section fade-in-up fade-in-up-2">
      <div class="section-title">Tech Stack</div>
      {Object.entries(skillCategories).map(([category, items]) => (
        <div class="skill-category">
          <div class="skill-cat-label">{category}</div>
          <div class="skill-tags">
            {items.map(s => <span class="skill-tag">{s}</span>)}
          </div>
        </div>
      ))}
    </section>

    <section class="section fade-in-up fade-in-up-3">
      <div class="section-title">Experience</div>
      <div class="timeline">
        {experience.map(item => (
          <div class="tl-item">
            <div class="tl-dot"></div>
            <div class="tl-period">{item.period}</div>
            <div class="tl-title">{item.title}</div>
            <div class="tl-org">{item.org}</div>
            <ul class="tl-bullets">
              {item.bullets.map(b => <li>{b}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="section fade-in-up fade-in-up-4">
      <div class="section-title">Education & Research</div>
      <div class="timeline">
        {education.map(item => (
          <div class="tl-item">
            <div class="tl-dot"></div>
            <div class="tl-period">{item.period}</div>
            <div class="tl-title">{item.title}</div>
            <div class="tl-org">{item.org}</div>
            {item.note && <p class="tl-note">{item.note}</p>}
          </div>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>

<style>
.container { max-width: 740px; margin: 0 auto; padding: 60px 24px 100px; }
.about-hero { display: flex; gap: 32px; align-items: center; margin-bottom: 56px; padding-bottom: 40px; border-bottom: 1px solid var(--border); }
.avatar-wrap { width: 112px; height: 112px; border-radius: 50%; border: 2px solid oklch(0.30 0.07 var(--hue)); box-shadow: 0 0 24px var(--accent-glow); flex-shrink: 0; overflow: hidden; }
.avatar-wrap img { width: 100%; height: 100%; object-fit: cover; }
.avatar-fallback { display: none; width: 100%; height: 100%; background: linear-gradient(135deg, oklch(0.20 0.04 var(--hue)), oklch(0.12 0.015 var(--hue))); align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 28px; font-weight: 600; color: var(--accent); }
.intro-name { font-size: 30px; letter-spacing: -0.03em; margin-bottom: 6px; }
.intro-role { font-family: var(--font-mono); font-size: 11px; color: var(--accent); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 12px; }
.intro-bio { font-size: 14px; color: var(--muted); line-height: 1.8; margin-bottom: 18px; }
.intro-socials { display: flex; gap: 10px; flex-wrap: wrap; }
.social-link { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--muted); padding: 6px 14px; border: 1px solid var(--border); border-radius: 8px; transition: all 0.15s; }
.social-link:hover { border-color: var(--accent); color: var(--accent); }
.section { margin-bottom: 52px; }
.section-title { font-family: var(--font-mono); font-size: 10px; letter-spacing: 3px; color: var(--accent); text-transform: uppercase; margin-bottom: 20px; padding-bottom: 8px; border-bottom: 1px solid var(--border); }
.skill-category { margin-bottom: 16px; }
.skill-cat-label { font-size: 11px; color: var(--text-secondary); margin-bottom: 8px; font-weight: 500; }
.skill-tags { display: flex; flex-wrap: wrap; gap: 7px; }
.skill-tag { background: oklch(0.17 0.018 var(--hue)); border: 1px solid oklch(0.25 0.04 var(--hue)); color: oklch(0.70 0.10 var(--hue)); padding: 4px 12px; border-radius: 20px; font-size: 12px; transition: all 0.15s; cursor: default; }
.skill-tag:hover { border-color: var(--accent); color: var(--accent); }
.timeline { display: flex; flex-direction: column; position: relative; padding-left: 20px; }
.timeline::before { content: ''; position: absolute; left: 0; top: 8px; bottom: 8px; width: 1px; background: var(--border); }
.tl-item { position: relative; padding: 0 0 32px 20px; }
.tl-item:last-child { padding-bottom: 0; }
.tl-dot { position: absolute; left: -4px; top: 6px; width: 9px; height: 9px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 8px var(--accent-glow); }
.tl-period { font-family: var(--font-mono); font-size: 10px; color: var(--accent); letter-spacing: 1px; margin-bottom: 4px; }
.tl-title { font-size: 15px; font-weight: 600; color: var(--text); margin-bottom: 2px; }
.tl-org { font-size: 12px; color: var(--muted); margin-bottom: 10px; }
.tl-bullets { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 5px; }
.tl-bullets li { font-size: 13px; color: var(--text-secondary); line-height: 1.65; padding-left: 14px; position: relative; }
.tl-bullets li::before { content: '·'; position: absolute; left: 0; color: var(--accent); }
.tl-note { font-size: 12px; color: var(--muted); line-height: 1.7; padding: 10px 14px; background: var(--bg-card); border: 1px solid var(--border); border-left: 3px solid var(--accent); border-radius: 6px; margin-top: 8px; }
@media (max-width: 560px) { .about-hero { flex-direction: column; text-align: center; } .avatar-wrap { width: 90px; height: 90px; } .intro-socials { justify-content: center; } }
</style>
